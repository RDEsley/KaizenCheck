rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validListCreate() {
      return request.resource.data.keys().hasOnly(["title", "color", "order", "createdAt", "updatedAt"])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.order is int;
    }

    function validTaskCreate() {
      return request.resource.data.keys().hasOnly([
          "title",
          "notes",
          "dueDate",
          "status",
          "order",
          "completedAt",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.status in ["pending", "completed"]
        && request.resource.data.order is int;
    }

    match /users/{userId} {
      allow read, write: if false;

      match /lists/{listId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validListCreate();
        allow update, delete: if isOwner(userId);

        match /tasks/{taskId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && validTaskCreate();
          allow update, delete: if isOwner(userId);
        }
      }
    }
  }
}
